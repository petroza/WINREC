<Window x:Class="WINREC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WINREC" Height="620" Width="620"
        ResizeMode="CanMinimize"
        Background="#0F172A"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0 header -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- 2 source type -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 4 source selector -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 6 region -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 8 audio -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 10 fps -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 12 quality + codec -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 14 output file -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- 16 status -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- 18 controls -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="12" Height="12" Fill="#EF4444" x:Name="RecordingIndicator"
                     Visibility="Collapsed" Margin="0,0,8,0"/>
            <TextBlock Text="WINREC" FontSize="22" FontWeight="Bold" Foreground="#F1F5F9"/>
            <TextBlock Text=" — Windows Screen Recorder" FontSize="14" Foreground="#64748B"
                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
        </StackPanel>

        <!-- Source type -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Source" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="SourceTypeCombo"
                      SelectionChanged="SourceTypeCombo_SelectionChanged">
                <ComboBoxItem Content="Full screen (monitor)" IsSelected="True" Tag="Display"/>
                <ComboBoxItem Content="Specific window" Tag="Window"/>
            </ComboBox>
        </Grid>

        <!-- Source selector -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SourceLabel" Text="Monitor" Foreground="#94A3B8"
                       FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="SourceCombo"/>
            <Button Grid.Column="3" Content="Refresh" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="RefreshSources_Click" Padding="10,6"/>
            <Button Grid.Column="5" x:Name="PickWindowBtn"
                    Content="🎯 Click to pick" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="PickWindow_Click" Padding="10,6"
                    Visibility="Collapsed"/>
        </Grid>

        <!-- Region picker -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Capture region" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="RegionBox"
                     Background="#1E293B" Foreground="#64748B"
                     BorderBrush="#334155" BorderThickness="1"
                     Padding="8,6" FontSize="11" IsReadOnly="True"
                     Text="Full screen / full window"/>
            <Button Grid.Column="3" Content="Draw region…" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="PickRegion_Click" Padding="10,6"/>
            <Button Grid.Column="5" x:Name="ClearRegionBtn" Content="✕ Clear"
                    Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="ClearRegion_Click" Padding="10,6"
                    Visibility="Collapsed"/>
        </Grid>

        <!-- Audio -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Audio" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <CheckBox x:Name="AudioOutputCheck"
                          Content="System audio (loopback)"
                          Foreground="#F1F5F9" FontSize="12" IsChecked="True" Margin="0,0,20,0"/>
                <CheckBox x:Name="AudioInputCheck"
                          Content="Microphone"
                          Foreground="#F1F5F9" FontSize="12" IsChecked="False"/>
            </StackPanel>
        </Grid>

        <!-- FPS -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Frame rate" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="FpsCombo">
                <ComboBoxItem Content="25 fps"  Tag="25"/>
                <ComboBoxItem Content="30 fps"  Tag="30" IsSelected="True"/>
                <ComboBoxItem Content="50 fps"  Tag="50"/>
                <ComboBoxItem Content="60 fps"  Tag="60"/>
            </ComboBox>
        </Grid>

        <!-- Quality + Codec -->
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Quality / Codec" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="QualityCombo">
                <ComboBoxItem Content="Low  — 2 Mbps"    Tag="2000"/>
                <ComboBoxItem Content="High — 6 Mbps"    Tag="6000" IsSelected="True"/>
                <ComboBoxItem Content="Ultra — 14 Mbps"  Tag="14000"/>
                <ComboBoxItem Content="Ultra+ — 25 Mbps" Tag="25000"/>
            </ComboBox>
            <ComboBox Grid.Column="3" x:Name="CodecCombo">
                <ComboBoxItem Content="H.264 (AVC)"  Tag="h264" IsSelected="True"/>
                <ComboBoxItem Content="H.265 (HEVC)" Tag="h265"/>
            </ComboBox>
        </Grid>

        <!-- Output file -->
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Output file" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="OutputPathBox"
                     Background="#1E293B" Foreground="#F1F5F9"
                     BorderBrush="#334155" BorderThickness="1"
                     Padding="8,6" FontSize="12" IsReadOnly="True"/>
            <Button Grid.Column="3" Content="Browse…" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="BrowseOutput_Click" Padding="10,6"/>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="16" Background="#1E293B" CornerRadius="6" Padding="12,8">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="Ready to record."
                           Foreground="#94A3B8" FontSize="12"/>
                <TextBlock x:Name="TimerText" Text=""
                           Foreground="#22C55E" FontSize="20" FontWeight="Bold"
                           Visibility="Collapsed" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="StartButton" Content="▶  Start recording"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="14" Height="42" Click="StartRecording_Click"/>
            <Button Grid.Column="2" x:Name="StopButton" Content="■  Stop"
                    Style="{StaticResource DangerButton}"
                    FontSize="14" Height="42" Width="130"
                    IsEnabled="False" Click="StopRecording_Click"/>
        </Grid>
    </Grid>
</Window>
