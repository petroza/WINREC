<Window x:Class="WINREC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WINREC" Height="540" Width="600"
        ResizeMode="CanMinimize"
        Background="#0F172A"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="12" Height="12" Fill="#EF4444" x:Name="RecordingIndicator"
                     Visibility="Collapsed" Margin="0,0,8,0"/>
            <TextBlock Text="WINREC" FontSize="22" FontWeight="Bold" Foreground="#F1F5F9"/>
            <TextBlock Text=" — Windows Screen Recorder" FontSize="14" Foreground="#64748B"
                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
        </StackPanel>

        <!-- Source type -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Zdroj záznamu" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="SourceTypeCombo"
                      SelectionChanged="SourceTypeCombo_SelectionChanged">
                <ComboBoxItem Content="Celá obrazovka (monitor)" IsSelected="True" Tag="Display"/>
                <ComboBoxItem Content="Konkrétní okno" Tag="Window"/>
            </ComboBox>
        </Grid>

        <!-- Source selector -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SourceLabel" Text="Monitor" Foreground="#94A3B8"
                       FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="SourceCombo"/>
            <Button Grid.Column="3" Content="Obnovit" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="RefreshSources_Click" Padding="10,6"/>
            <Button Grid.Column="5" x:Name="PickWindowBtn"
                    Content="🎯 Vybrat kliknutím" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="PickWindow_Click" Padding="10,6"
                    Visibility="Collapsed"/>
        </Grid>

        <!-- Region picker -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Oblast záznamu" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="RegionBox"
                     Background="#1E293B" Foreground="#64748B"
                     BorderBrush="#334155" BorderThickness="1"
                     Padding="8,6" FontSize="11" IsReadOnly="True"
                     Text="Celá plocha / celé okno"/>
            <Button Grid.Column="3" Content="Vybrat myší…" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="PickRegion_Click" Padding="10,6"/>
        </Grid>

        <!-- Audio -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Zvuk" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1">
                <CheckBox x:Name="AudioOutputCheck"
                          Content="Zvuk systému (reproduktory / loopback)"
                          Foreground="#F1F5F9" FontSize="12" IsChecked="True" Margin="0,0,0,6"/>
                <CheckBox x:Name="AudioInputCheck"
                          Content="Mikrofon"
                          Foreground="#F1F5F9" FontSize="12" IsChecked="False"/>
            </StackPanel>
        </Grid>

        <!-- Quality -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Kvalita videa" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="QualityCombo">
                <ComboBoxItem Content="Vysoká (4000 kbps)" Tag="4000" IsSelected="True"/>
                <ComboBoxItem Content="Střední (2000 kbps)" Tag="2000"/>
                <ComboBoxItem Content="Nízká (1000 kbps)" Tag="1000"/>
            </ComboBox>
        </Grid>

        <!-- Output file -->
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Výstupní soubor" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="OutputPathBox"
                     Background="#1E293B" Foreground="#F1F5F9"
                     BorderBrush="#334155" BorderThickness="1"
                     Padding="8,6" FontSize="12" IsReadOnly="True"/>
            <Button Grid.Column="3" Content="Procházet…" Style="{StaticResource SecondaryButton}"
                    FontSize="11" Click="BrowseOutput_Click" Padding="10,6"/>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="13" Background="#1E293B" CornerRadius="6" Padding="12,8"
                VerticalAlignment="Bottom" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="Připraveno k záznamu."
                           Foreground="#94A3B8" FontSize="12"/>
                <TextBlock x:Name="TimerText" Text=""
                           Foreground="#22C55E" FontSize="20" FontWeight="Bold"
                           Visibility="Collapsed" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="StartButton" Content="▶  Spustit záznam"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="14" Height="42" Click="StartRecording_Click"/>
            <Button Grid.Column="2" x:Name="StopButton" Content="■  Zastavit"
                    Style="{StaticResource DangerButton}"
                    FontSize="14" Height="42" Width="130"
                    IsEnabled="False" Click="StopRecording_Click"/>
        </Grid>
    </Grid>
</Window>
